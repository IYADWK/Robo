<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Robot Tri Déchets</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { background: #111; color: white; font-family: Arial, sans-serif; }
  #setup { padding: 20px; }
  #setup input {
    width: 100%; padding: 12px; margin: 10px 0;
    font-size: 16px; border-radius: 8px; border: none;
  }
  #setup button {
    width: 100%; padding: 15px;
    background: #4CAF50; color: white;
    font-size: 18px; border: none; border-radius: 8px;
  }
  #scanner { display: none; }
  #video {
    width: 100%; max-height: 50vh;
    object-fit: cover;
  }
  #scanBtn {
    width: 100%; padding: 20px;
    background: #2196F3; color: white;
    font-size: 22px; font-weight: bold;
    border: none; cursor: pointer;
  }
  #result {
    display: none;
    position: fixed; top: 0; left: 0;
    width: 100%; height: 100%;
    justify-content: center; align-items: center;
    flex-direction: column;
    font-size: 48px; font-weight: bold; color: white;
  }
  #result button {
    margin-top: 30px; padding: 15px 30px;
    font-size: 20px; border: none; border-radius: 10px;
    background: white; cursor: pointer;
  }
  canvas { display: none; }
</style>
</head>
<body>

<div id="setup">
  <h2>🤖 Robot Tri Déchets</h2>
  <p>Entre ta clé API Gemini :</p>
  <input type="text" id="apiKey" placeholder="AIzaSy..." />
  <button onclick="startScanner()">▶ Démarrer</button>
</div>

<div id="scanner">
  <video id="video" autoplay playsinline></video>
  <canvas id="canvas"></canvas>
  <button id="scanBtn" onclick="analyser()">📷 ANALYSER</button>
  <p id="status" style="text-align:center;padding:10px;font-size:16px;">Prêt</p>
</div>

<div id="result">
  <span id="resultText"></span>
  <button onclick="retour()">🔄 Retour</button>
</div>

<script>
let apiKey = "";
let stream = null;

function startScanner() {
  apiKey = document.getElementById("apiKey").value.trim();
  if (!apiKey) { alert("Entre ta clé API !"); return; }
  localStorage.setItem("geminiKey", apiKey);

  document.getElementById("setup").style.display = "none";
  document.getElementById("scanner").style.display = "block";

  navigator.mediaDevices.getUserMedia({ video: { facingMode: "environment" } })
    .then(s => {
      stream = s;
      document.getElementById("video").srcObject = s;
    })
    .catch(e => alert("Erreur caméra : " + e));
}

async function analyser() {
  document.getElementById("status").textContent = "⏳ Analyse en cours...";
  document.getElementById("scanBtn").disabled = true;

  const video = document.getElementById("video");
  const canvas = document.getElementById("canvas");
  canvas.width = 512;
  canvas.height = 512;
  const ctx = canvas.getContext("2d");
  ctx.drawImage(video, 0, 0, 512, 512);
  const imageData = canvas.toDataURL("image/jpeg", 0.7).split(",")[1];

  try {
    const response = await fetch(
      `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash-lite:generateContent?key=${apiKey}`,
      {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          contents: [{
            parts: [
              { text: "Regarde cette image. Ignore le robot. Concentre-toi uniquement sur l'objet tenu par la pince du robot. Est-ce que cet objet est en métal, plastique ou papier ? Réponds avec un seul mot : METAL, PLASTIQUE, ou PAPIER." },
              { inline_data: { mime_type: "image/jpeg", data: imageData } }
            ]
          }]
        })
      }
    );

    const data = await response.json();
    const reponse = data.candidates[0].content.parts[0].text.trim().toUpperCase();

    let couleur = "#111";
    let label = reponse;

    if (reponse.includes("METAL")) { couleur = "#e53935"; label = "🔴 MÉTAL"; }
    else if (reponse.includes("PLASTIQUE")) { couleur = "#1565C0"; label = "🔵 PLASTIQUE"; }
    else if (reponse.includes("PAPIER")) { couleur = "#2E7D32"; label = "🟢 PAPIER"; }

    const result = document.getElementById("result");
    result.style.background = couleur;
    result.style.display = "flex";
    document.getElementById("resultText").textContent = label;

  } catch(e) {
    document.getElementById("status").textContent = "❌ Erreur : " + e.message;
  }

  document.getElementById("scanBtn").disabled = false;
}

function retour() {
  document.getElementById("result").style.display = "none";
  document.getElementById("status").textContent = "Prêt";
}

window.onload = () => {
  const saved = localStorage.getItem("geminiKey");
  if (saved) document.getElementById("apiKey").value = saved;
};
</script>

</body>
</html>
